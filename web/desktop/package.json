{
  "name": "@openstoryforge/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.cjs",
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('out',{recursive:true,force:true});\"",
    "dev": "npm run build:electron && concurrently -k -n vite,electron -c cyan,green \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron out/main/index.cjs\"",
    "dev:web": "vite --host 127.0.0.1",
    "build": "npm run typecheck && npm run clean && npm run build:electron && vite build --outDir out/renderer",
    "build:electron": "npm run build:main && npm run build:preload",
    "build:main": "esbuild electron/main.ts --bundle --platform=node --format=cjs --external:electron --outfile=out/main/index.cjs",
    "build:preload": "esbuild electron/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=out/preload/index.cjs",
    "preview": "npm run build && electron out/main/index.cjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.13.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "electron": "^42.4.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  }
}
