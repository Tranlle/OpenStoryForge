###############################################################################
# Auto detect text files and normalize line endings
###############################################################################

* text=auto


###############################################################################
# C# / .NET source files
###############################################################################

*.cs       text eol=crlf
*.csx      text eol=crlf
*.csproj   text eol=crlf
*.sln      text eol=crlf
*.slnx     text eol=crlf
*.props    text eol=crlf
*.targets  text eol=crlf
*.resx     text eol=crlf
*.xaml     text eol=crlf
*.axaml    text eol=crlf
*.razor    text eol=crlf
*.cshtml   text eol=crlf
*.config   text eol=crlf
*.ruleset  text eol=crlf
*.editorconfig text eol=crlf


###############################################################################
# Scripts
###############################################################################

*.ps1      text eol=crlf
*.psm1     text eol=crlf
*.psd1     text eol=crlf
*.bat      text eol=crlf
*.cmd      text eol=crlf

*.sh       text eol=lf
*.bash     text eol=lf


###############################################################################
# Cross-platform text files
###############################################################################

*.md       text eol=lf
*.txt      text eol=lf
*.json     text eol=lf
*.jsonc    text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.toml     text eol=lf
*.xml      text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.scss     text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.mjs      text eol=lf
*.cjs      text eol=lf
*.sql      text eol=lf
*.graphql  text eol=lf
*.proto    text eol=lf


###############################################################################
# GitHub language statistics / generated files
###############################################################################

# Build output
bin/** linguist-generated
obj/** linguist-generated

# Generated C# files
*.g.cs          linguist-generated
*.generated.cs  linguist-generated
*.Designer.cs   linguist-generated

# Minified frontend bundles
*.min.js        linguist-generated
*.min.css       linguist-generated

# Lock files are important, but usually not useful in GitHub language stats
package-lock.json linguist-generated
pnpm-lock.yaml   linguist-generated
yarn.lock        linguist-generated
packages.lock.json linguist-generated


###############################################################################
# Binary files
###############################################################################

*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.ico      binary
*.bmp      binary
*.tiff     binary
*.svgz     binary

*.pdf      binary
*.zip      binary
*.rar      binary
*.7z       binary
*.tar      binary
*.gz       binary

*.dll      binary
*.exe      binary
*.pdb      binary
*.snk      binary
*.nupkg    binary
*.vsix     binary

*.woff     binary
*.woff2    binary
*.ttf      binary
*.otf      binary

*.mp3      binary
*.wav      binary
*.ogg      binary
*.mp4      binary
*.mov      binary
*.avi      binary
*.webm     binary


###############################################################################
# Git archive exclusions
###############################################################################

.github/ export-ignore
.vscode/ export-ignore
.idea/ export-ignore
*.user export-ignore
*.suo export-ignore